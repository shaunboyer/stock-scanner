# Financial Modeling Prep
FMP_API_KEY=your_fmp_key_here

# Claude API (for per-stock narratives)
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Postgres (Render provides this automatically as DATABASE_URL when you attach a Postgres instance)
DATABASE_URL=postgres://user:password@localhost:5432/stock_scanner

# Scan tuning
PCT_FROM_52W_LOW_MAX=15
PCT_DRAWDOWN_3M_MIN=20

# Scan universe: comma-separated tickers, overrides backend/data/watchlist.js.
# There's no market-wide screener on this FMP plan (confirmed — company-screener
# and batch-quote return no data), so the scan only checks tickers listed here.
# Leave unset to use the default list in backend/data/watchlist.js.
# WATCHLIST_TICKERS=AAPL,MSFT,GOOGL,...

# Daily FMP call budget (Basic plan = 250/day). runScan.js logs actual usage
# each run so you can size WATCHLIST_TICKERS to fit.
MAX_DAILY_FMP_CALLS=250

# Set to "true" only after confirming your FMP plan actually returns data for
# insider-trading/search and news/stock (both empty on Basic as of this write-up).
ENABLE_NEWS_AND_INSIDER=false

PORT=4000
